# SMTP — use app password / auth code, NEVER commit real secrets
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_account@example.com
SMTP_PASS=your_auth_code_here
SMTP_SSL=true

EMAIL_TO=your_inbox@example.com
EMAIL_FROM=your_account@example.com
EMAIL_FROM_NAME=A-Share Market Review

# DeepSeek（OpenAI 兼容）— 完整复盘与本地模板对齐
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
