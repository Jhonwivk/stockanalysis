<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Template: install_local_schedule.sh substitutes __REPO__ before installing. -->
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.stockanalysis.daily-review</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__REPO__/scripts/__RUNNER__</string>
	</array>
	<key>WorkingDirectory</key>
	<string>__REPO__</string>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>8</integer>
		<key>Minute</key>
		<integer>30</integer>
	</dict>
	<key>StandardOutPath</key>
	<string>__HOME__/Library/Logs/stockanalysis-daily-review.log</string>
	<key>StandardErrorPath</key>
	<string>__HOME__/Library/Logs/stockanalysis-daily-review.log</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
		<key>HOME</key>
		<string>__HOME__</string>
		<key>LANG</key>
		<string>en_US.UTF-8</string>
		<key>TZ</key>
		<string>__TZ__</string>
	</dict>
	<key>RunAtLoad</key>
	<false/>
</dict>
</plist>
